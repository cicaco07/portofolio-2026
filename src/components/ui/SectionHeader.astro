---
interface Props {
	number: string;
	title: string;
	subtitle?: string;
	centered?: boolean;
}

const { number, title, subtitle, centered = false } = Astro.props;
---

<div class={`reveal mb-16 ${centered ? 'text-center' : ''}`}>
	<p class="mb-2 font-mono text-sm font-medium text-primary">{number}</p>
	<h2 class={`section-title text-3xl font-bold tracking-tight sm:text-4xl ${centered ? 'inline-block' : ''}`}>
		{title}
	</h2>
	{subtitle && (
		<p class={`mt-6 max-w-2xl opacity-70 ${centered ? 'mx-auto' : ''}`}>
			{subtitle}
		</p>
	)}
</div>
