---
import commitActivity from '../data/commit-activity.json';
import { UI } from '../i18n';
import SectionHeader from './ui/SectionHeader.astro';
import T from './ui/T.astro';

const STALE_DAYS = 7;
const isAvailable = commitActivity.available === true && commitActivity.activity.length > 0;
const isStale =
	commitActivity.fetchedAt !== null &&
	Date.now() - new Date(commitActivity.fetchedAt).getTime() >= STALE_DAYS * 24 * 60 * 60 * 1000;

const chartData = JSON.stringify({
	activity: commitActivity.activity,
	totals: commitActivity.totals,
	github: commitActivity.github,
	gitlab: commitActivity.gitlab,
});
---

<section id="commit-activity" class="relative py-24 px-6">
	<div class="mx-auto max-w-6xl">
		<SectionHeader
			number={UI.section.commitActivity.number}
			title={UI.section.commitActivity.title}
			subtitle={UI.section.commitActivity.subtitle}
		/>

		{(!isAvailable || isStale) && (
			<div class="mt-8 rounded-lg border border-base-content/10 bg-base-content/[0.03] px-4 py-3 text-sm opacity-70">
				{!isAvailable ? <T tr={UI.section.commitActivity.unavailable} /> : <T tr={UI.section.commitActivity.stale} />}
			</div>
		)}

		<div class="mt-10 grid max-w-sm grid-cols-3 gap-4">
			<div class="glass rounded-lg p-4 text-center">
				<div class="text-2xl font-extrabold text-primary">{commitActivity.totals.all}</div>
				<div class="mt-1 font-mono text-xs uppercase tracking-wider opacity-50">
					<T tr={UI.section.commitActivity.totalCommits} />
				</div>
			</div>
			<div class="glass rounded-lg p-4 text-center">
				<div class="text-2xl font-extrabold text-secondary">{commitActivity.totals.github}</div>
				<div class="mt-1 font-mono text-xs uppercase tracking-wider opacity-50">
					<T tr={UI.section.commitActivity.github} />
				</div>
			</div>
			<div class="glass rounded-lg p-4 text-center">
				<div class="text-2xl font-extrabold text-accent">{commitActivity.totals.gitlab}</div>
				<div class="mt-1 font-mono text-xs uppercase tracking-wider opacity-50">
					<T tr={UI.section.commitActivity.gitlab} />
				</div>
			</div>
		</div>

		<div class="glass mt-8 overflow-x-auto rounded-lg p-4 sm:p-6 lg:p-8">
			<canvas id="commit-heatmap-canvas" style="min-height: 210px;"></canvas>
		</div>

		<p class="mt-3 font-mono text-xs opacity-40">
			<T tr={UI.section.commitActivity.updatedAt} />: {commitActivity.fetchedAt ? new Date(commitActivity.fetchedAt).toLocaleDateString() : '-'}
		</p>
	</div>

	<script id="commit-activity-data" type="application/json" set:html={chartData} />
</section>

<script>
	import { initCommitHeatmap } from '../scripts/commit-heatmap';
	initCommitHeatmap();
</script>
