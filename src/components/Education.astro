---
import { educations } from '../data/education';
import { UI } from '../i18n';
import SectionHeader from './ui/SectionHeader.astro';
import T from './ui/T.astro';
---

<section id="education" class="relative py-24 px-6">
	<div class="mx-auto max-w-4xl">
		<SectionHeader number={UI.section.education.number} title={UI.section.education.title} />

		<div class="relative">
			<div class="timeline-line"></div>

			{educations.map((edu, i) => (
				<div class={`reveal relative pb-12 last:pb-0 pl-12 md:pl-0 ${i % 2 === 0 ? 'md:pr-[calc(50%+2rem)] md:text-right' : 'md:pl-[calc(50%+2rem)]'}`}>
					<div class="timeline-dot"></div>
					<div class="glass glass-hover rounded-2xl p-6">
						<span class="inline-block rounded-full bg-primary/10 px-3 py-1 font-mono text-xs font-medium text-primary mb-3">
							{edu.period}
						</span>
						<h3 class="text-xl font-bold"><T tr={edu.degree} /></h3>
						<p class="mt-1 font-medium text-primary/80">{edu.institution}</p>
						<p class="mt-3 text-sm leading-relaxed opacity-70"><T tr={edu.description} /></p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
