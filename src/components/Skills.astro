---
import { coreSkills, innerRing, middleRing, outerRing, allSkills, BENTO_SIZE_PATTERN } from '../data/skills';
import SectionHeader from './ui/SectionHeader.astro';
import OrbitItem from './ui/OrbitItem.astro';
import BentoItem from './ui/BentoItem.astro';
---

<section id="skills" class="relative py-24 px-6 overflow-hidden">
	<div class="mx-auto max-w-6xl">
		<SectionHeader
			number="04. Skills"
			title="Tech Universe"
			subtitle="Ecosystem teknologi yang saya kuasai — hover untuk pause dan lihat detail."
			centered
		/>
	</div>

	<div class="orbital-wrapper">
		<div class="orbital-stage">
			<div class="orbital-glow orbital-glow--1"></div>
			<div class="orbital-glow orbital-glow--2"></div>

			<div class="orbit-ring orbit-ring--inner"></div>
			<div class="orbit-ring orbit-ring--middle"></div>
			<div class="orbit-ring orbit-ring--outer"></div>

			<div class="orbital-core">
				<div class="orbital-core__inner">
					<div class="orbital-core__grid">
						{coreSkills.map((skill) => (
							<div class="orbital-core__item" style={`--brand: #${skill.hex};`}>
								<svg viewBox="0 0 24 24" class="orbital-core__svg" aria-hidden="true">
									<path d={skill.path} />
								</svg>
							</div>
						))}
					</div>
				</div>
				<span class="orbital-core__label">Core</span>
			</div>

			<div class="orbit orbit--inner">
				{innerRing.map((skill, i) => (
					<OrbitItem
						title={skill.title}
						hex={skill.hex}
						path={skill.path}
						angle={(360 / innerRing.length) * i}
						radius="min(120px, 18vw)"
					/>
				))}
			</div>

			<div class="orbit orbit--middle">
				{middleRing.map((skill, i) => (
					<OrbitItem
						title={skill.title}
						hex={skill.hex}
						path={skill.path}
						angle={(360 / middleRing.length) * i}
						radius="min(210px, 27vw)"
					/>
				))}
			</div>

			<div class="orbit orbit--outer">
				{outerRing.map((skill, i) => (
					<OrbitItem
						title={skill.title}
						hex={skill.hex}
						path={skill.path}
						angle={(360 / outerRing.length) * i}
						radius="min(300px, 36vw)"
					/>
				))}
			</div>
		</div>
	</div>

	<div class="bento-wrapper">
		<div class="bento-grid">
			{allSkills.map((skill, i) => (
				<BentoItem
					title={skill.title}
					hex={skill.hex}
					path={skill.path}
					size={BENTO_SIZE_PATTERN[i] ?? 's'}
				/>
			))}
		</div>
	</div>
</section>

<style>
	@media (max-width: 1023px) {
		.orbital-wrapper { display: none; }
		.bento-wrapper   { display: block; }
	}

	.orbital-wrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: clamp(480px, 70vw, 680px);
		padding: 2rem 0;
	}
	.bento-wrapper { display: none; }

	.orbital-stage {
		position: relative;
		width: clamp(420px, 62vw, 680px);
		height: clamp(420px, 62vw, 680px);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.orbital-glow {
		position: absolute;
		border-radius: 9999px;
		filter: blur(80px);
		pointer-events: none;
	}
	.orbital-glow--1 {
		width: 300px; height: 300px;
		background: color-mix(in oklch, var(--color-primary) 40%, transparent);
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		opacity: 0.4;
		animation: glow-pulse 4s ease-in-out infinite;
	}
	.orbital-glow--2 {
		width: 500px; height: 500px;
		background: color-mix(in oklch, var(--color-accent) 20%, transparent);
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		opacity: 0.25;
		animation: glow-pulse 6s ease-in-out infinite reverse;
	}

	@keyframes glow-pulse {
		0%, 100% { opacity: 0.2; }
		50%       { opacity: 0.5; }
	}

	.orbit-ring {
		position: absolute;
		top: 50%; left: 50%;
		border-radius: 9999px;
		border: 1px dashed color-mix(in oklch, var(--color-base-content) 10%, transparent);
		pointer-events: none;
		transform: translate(-50%, -50%);
	}
	.orbit-ring--inner  { width: min(240px, 36vw); height: min(240px, 36vw); }
	.orbit-ring--middle { width: min(420px, 54vw); height: min(420px, 54vw); }
	.orbit-ring--outer  { width: min(600px, 72vw); height: min(600px, 72vw); }

	.orbital-core {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		z-index: 5;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
	}
	.orbital-core__inner {
		width: clamp(88px, 12vw, 120px);
		height: clamp(88px, 12vw, 120px);
		border-radius: 9999px;
		background: linear-gradient(135deg, var(--color-primary), var(--color-secondary), var(--color-accent));
		padding: 3px;
		box-shadow: 0 0 60px color-mix(in oklch, var(--color-primary) 40%, transparent);
		animation: core-pulse 3s ease-in-out infinite;
	}
	.orbital-core__grid {
		width: 100%; height: 100%;
		border-radius: 9999px;
		background: var(--color-base-100);
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		align-items: center;
		justify-items: center;
		padding: 1rem;
		gap: 0.25rem;
	}
	.orbital-core__item { display: flex; align-items: center; justify-content: center; }
	.orbital-core__svg  { width: clamp(24px, 3vw, 32px); height: clamp(24px, 3vw, 32px); fill: var(--brand); }
	.orbital-core__label {
		font-family: var(--font-mono, monospace);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-primary);
		opacity: 0.8;
	}

	@keyframes core-pulse {
		0%, 100% { box-shadow: 0 0 60px color-mix(in oklch, var(--color-primary) 40%, transparent); }
		50%       { box-shadow: 0 0 90px color-mix(in oklch, var(--color-primary) 60%, transparent); }
	}

	.orbit {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		will-change: transform;
	}
	.orbit--inner  { width: min(240px, 36vw); height: min(240px, 36vw); animation: orbit-cw  30s linear infinite; }
	.orbit--middle { width: min(420px, 54vw); height: min(420px, 54vw); animation: orbit-ccw 45s linear infinite; }
	.orbit--outer  { width: min(600px, 72vw); height: min(600px, 72vw); animation: orbit-cw  60s linear infinite; }

	@keyframes orbit-cw  { from { transform: translate(-50%,-50%) rotate(0deg);    } to { transform: translate(-50%,-50%) rotate(360deg);  } }
	@keyframes orbit-ccw { from { transform: translate(-50%,-50%) rotate(0deg);    } to { transform: translate(-50%,-50%) rotate(-360deg); } }

	.orbital-stage:hover .orbit,
	.orbital-stage:hover .orbit-item__inner { animation-play-state: paused; }

	:global(.orbit-item) {
		position: absolute;
		top: 50%; left: 50%;
		width: 0; height: 0;
		transform: rotate(var(--angle)) translateY(calc(var(--radius) * -1));
	}
	:global(.orbit-item__inner) {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 3.25rem; height: 3.25rem;
		border-radius: 1rem;
		background: color-mix(in oklch, var(--color-base-200) 80%, transparent);
		border: 1px solid color-mix(in oklch, var(--color-base-content) 10%, transparent);
		display: flex; align-items: center; justify-content: center;
		backdrop-filter: blur(8px);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		cursor: pointer;
		will-change: transform;
	}
	.orbit--inner  :global(.orbit-item__inner) { animation: counter-cw  30s linear infinite; }
	.orbit--middle :global(.orbit-item__inner) { animation: counter-ccw 45s linear infinite; }
	.orbit--outer  :global(.orbit-item__inner) { animation: counter-cw  60s linear infinite; }

	@keyframes counter-cw  { from { transform: translate(-50%,-50%) rotate(0deg);   } to { transform: translate(-50%,-50%) rotate(-360deg); } }
	@keyframes counter-ccw { from { transform: translate(-50%,-50%) rotate(0deg);   } to { transform: translate(-50%,-50%) rotate(360deg);  } }

	:global(.orbit-item:hover .orbit-item__inner) {
		transform: translate(-50%, -50%) scale(1.2);
		background: color-mix(in oklch, var(--brand) 15%, var(--color-base-100));
		border-color: var(--brand);
		box-shadow: 0 0 24px color-mix(in oklch, var(--brand) 40%, transparent);
		z-index: 10;
	}
	:global(.orbit-item__svg) {
		width: 1.75rem; height: 1.75rem;
		fill: color-mix(in oklch, var(--color-base-content) 65%, transparent);
		transition: fill 0.3s ease;
	}
	:global(.orbit-item:hover .orbit-item__svg) { fill: var(--brand); }
	:global(.orbit-item__tooltip) {
		position: absolute;
		top: 100%; left: 50%;
		transform: translate(-50%, 0.75rem);
		font-family: var(--font-mono, monospace);
		font-size: 0.7rem; font-weight: 500;
		white-space: nowrap;
		padding: 0.25rem 0.625rem;
		border-radius: 0.5rem;
		background: var(--color-base-100);
		border: 1px solid color-mix(in oklch, var(--color-base-content) 15%, transparent);
		color: var(--brand);
		opacity: 0; pointer-events: none;
		transition: opacity 0.25s ease, transform 0.25s ease;
		z-index: 20;
	}
	:global(.orbit-item:hover .orbit-item__tooltip) { opacity: 1; transform: translate(-50%, 1rem); }

	.bento-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.75rem;
		grid-auto-flow: dense;
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	:global(.bento-item) {
		display: flex; flex-direction: column;
		align-items: center; justify-content: center;
		gap: 0.4rem; padding: 1rem 0.75rem;
		border-radius: 1rem;
		border: 1px solid color-mix(in oklch, var(--color-base-content) 8%, transparent);
		background: color-mix(in oklch, var(--color-base-200) 50%, transparent);
		transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
		min-height: 5rem;
	}
	:global(.bento-item--s) { grid-column: span 1; }
	:global(.bento-item--m) { grid-column: span 2; }
	:global(.bento-item--l) { grid-column: span 2; grid-row: span 2; min-height: 10rem; }
	:global(.bento-item:hover) {
		border-color: var(--brand, var(--color-primary));
		background: color-mix(in oklch, var(--brand, var(--color-primary)) 10%, var(--color-base-200));
		transform: translateY(-3px);
		box-shadow: 0 8px 24px color-mix(in oklch, var(--brand, var(--color-primary)) 20%, transparent);
	}
	:global(.bento-svg) {
		width: 1.75rem; height: 1.75rem;
		fill: color-mix(in oklch, var(--color-base-content) 60%, transparent);
		transition: fill 0.25s ease;
	}
	:global(.bento-item--l .bento-svg) { width: 2.5rem; height: 2.5rem; }
	:global(.bento-item:hover .bento-svg) { fill: var(--brand); }
	:global(.bento-name) {
		font-family: var(--font-mono, monospace);
		font-size: 0.6rem; font-weight: 500;
		opacity: 0.6; white-space: nowrap; text-align: center;
	}
	:global(.bento-item:hover .bento-name) { opacity: 1; }
</style>
