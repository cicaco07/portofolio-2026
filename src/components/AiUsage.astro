---
import aiUsage from '../data/ai-usage.json';
import { UI } from '../i18n';
import SectionHeader from './ui/SectionHeader.astro';
import T from './ui/T.astro';

const STALE_DAYS = 7;
const isAvailable =
	aiUsage.available === true &&
	aiUsage.fetchedAt !== null &&
	Date.now() - new Date(aiUsage.fetchedAt).getTime() < STALE_DAYS * 24 * 60 * 60 * 1000;

function fmtCompactTokens(n: number) {
	return new Intl.NumberFormat('en-US', {
		notation: 'compact',
		maximumFractionDigits: 1,
	}).format(n);
}
function fmtCost(n: number) {
	return '$' + n.toFixed(2);
}
function fmtCompactCost(n: number) {
	return '$' + fmtCompactTokens(n);
}

const { totals, stats, activity, models, clients } = aiUsage;
const usageYear = aiUsage.fetchedAt ? new Date(aiUsage.fetchedAt).getFullYear() : new Date().getFullYear();
const modelRows = models
	.map((model) => ({
		...model,
		cost: Number(model.cost ?? 0),
		percentage:
			Number(model.percentage ?? 0) > 0
				? Number(model.percentage)
				: totals.cost > 0
					? (Number(model.cost ?? 0) / totals.cost) * 100
					: totals.tokens > 0
						? (Number(model.tokens ?? 0) / totals.tokens) * 100
						: 0,
	}))
	.filter((model) => model.name && Number(model.tokens) > 0);
const modelColor = (name: string) => (name.toLowerCase().includes('gpt') ? 'bg-accent' : 'bg-secondary');

const toolMeta: Record<string, { label: string; icon: string }> = {
	claude: { label: 'Claude Code', icon: '/icons/ai-tools/claude.svg' },
	kiro: { label: 'Kiro', icon: '/icons/ai-tools/kiro.svg' },
	opencode: { label: 'OpenCode', icon: '/icons/ai-tools/opencode.png' },
	hermes: { label: 'Hermes Agent', icon: '/icons/ai-tools/hermes.png' },
	codex: { label: 'Codex CLI', icon: '/icons/ai-tools/codex.svg' },
	droid: { label: 'Droid', icon: '/icons/ai-tools/droid.svg' },
};
const clientRows = clients
	.map((client) => ({
		...client,
		key: String(client.name).toLowerCase(),
		tokens: Number(client.tokens ?? 0),
		percentage: Number(client.percentage ?? 0),
	}))
	.filter((client) => client.key && client.tokens > 0)
	.sort((a, b) => b.tokens - a.tokens);

const statCards = [
	{ label: UI.section.aiUsage.totalTokens,   value: totals.tokens    > 0 ? fmtCompactTokens(totals.tokens) : null },
	{ label: UI.section.aiUsage.totalCost,     value: totals.cost      > 0 ? fmtCompactCost(totals.cost)     : null },
	{ label: UI.section.aiUsage.activeDays,    value: totals.activeDays > 0 ? String(totals.activeDays)  : null },
	{ label: UI.section.aiUsage.streak,        value: stats.streak     > 0 ? stats.streak + ' days'      : null },
].filter((c): c is { label: typeof c.label; value: string } => c.value !== null);

const chartData = JSON.stringify({ activity, models });
---

{isAvailable && (
	<section id="ai-usage" class="relative py-24 px-6">
		<div class="mx-auto max-w-6xl">
			<SectionHeader
				number={UI.section.aiUsage.number}
				title={UI.section.aiUsage.title}
				subtitle={UI.section.aiUsage.subtitle}
			/>

			{statCards.length > 0 && (
				<div class="reveal grid grid-cols-2 gap-4 sm:grid-cols-3 mb-12">
					{statCards.map((card) => (
						<div class="glass rounded-2xl p-5 flex flex-col gap-1">
							<span class="text-2xl font-extrabold text-primary">{card.value}</span>
							<span class="font-mono text-xs opacity-50 uppercase tracking-wider">
								<T tr={card.label} />
							</span>
						</div>
					))}
				</div>
			)}

			{clientRows.length > 0 && (
				<div class="reveal glass rounded-2xl border border-primary/20 bg-base-200/35 p-5 sm:p-7 mb-12">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-5">
						<div>
							<p class="font-mono text-xs uppercase tracking-[0.24em] text-info/70">Filter:</p>
							<h3 class="mt-1 text-lg font-extrabold uppercase tracking-wider">AI Usage Tools</h3>
						</div>
						<p class="font-mono text-xs text-base-content/50">{clientRows.length} tools tracked</p>
					</div>
					<div class="flex flex-wrap gap-3">
						{clientRows.map((client) => {
							const meta = toolMeta[client.key] ?? {
								label: client.name,
								icon: null,
							};
							return (
								<div class="group inline-flex items-center gap-3 rounded-full border border-primary/70 bg-primary/10 px-3 py-2 text-sm font-semibold text-base-content shadow-[0_0_0_1px_rgba(20,184,166,0.08)] transition hover:-translate-y-0.5 hover:border-primary hover:bg-primary/15 hover:shadow-[0_0_24px_rgba(20,184,166,0.18)]">
									<span class="grid h-7 w-7 shrink-0 place-items-center overflow-hidden rounded-full bg-base-300 ring-1 ring-white/20">
										{meta.icon ? (
											<img src={meta.icon} alt="" class="h-full w-full object-contain p-0.5" loading="lazy" />
										) : (
											<span class="text-[11px] font-black text-primary">{client.name.slice(0, 1).toUpperCase()}</span>
										)}
									</span>
									<span>{meta.label}</span>
									<span class="font-mono text-[11px] text-info/80">{client.percentage.toFixed(1)}%</span>
								</div>
							);
						})}
					</div>
				</div>
			)}

			<div class="reveal glass rounded-2xl overflow-hidden mb-12">
				<div class="border-b border-base-content/10 bg-base-200/40 p-5 sm:p-7">
					<div class="flex items-center justify-between">
						<h3 class="flex items-center gap-2 text-lg font-extrabold uppercase tracking-wider">
							<span class="inline-block h-5 w-1.5 rounded-sm bg-primary"></span>
							Activity
						</h3>
						<p class="font-mono text-xs text-base-content/50">
							{fmtCost(totals.cost)} · {fmtCompactTokens(totals.tokens)}
						</p>
					</div>
					<div class="mt-6">
						<canvas
							id="ai-usage-activity-heatmap"
							data-ai-usage-heatmap
							class="block w-full"
							aria-label="Token activity heatmap"
						></canvas>
					</div>
					<div class="mt-3 flex items-center gap-2 text-xs text-base-content/50">
						<span class="font-mono">less</span>
						<span class="inline-block h-3 w-3 rounded-sm bg-base-content/5"></span>
						<span class="inline-block h-3 w-3 rounded-sm bg-primary/25"></span>
						<span class="inline-block h-3 w-3 rounded-sm bg-primary/50"></span>
						<span class="inline-block h-3 w-3 rounded-sm bg-primary/75"></span>
						<span class="inline-block h-3 w-3 rounded-sm bg-primary"></span>
						<span class="font-mono">more</span>
					</div>
				</div>

				<div class="border-t border-base-content/10 p-5 sm:p-7">
					<div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
						<h3 class="flex items-center gap-2 text-lg font-extrabold uppercase tracking-wider">
							<span class="inline-block h-5 w-1.5 rounded-sm bg-primary"></span>
							Model Usage Comparison
						</h3>
						<div class="flex flex-wrap gap-3 font-mono text-xs">
							<label class="flex flex-col gap-1 text-base-content/50">Range
								<select class="rounded-lg border border-base-content/15 bg-base-200 px-3 py-2 text-base-content" data-ai-usage-range>
									<option value="1">1 day</option><option value="7">7 days</option><option value="30" selected>30 days</option><option value="90">90 days</option>
								</select>
							</label>
							<label class="flex flex-col gap-1 text-base-content/50">Client
								<select class="rounded-lg border border-base-content/15 bg-base-200 px-3 py-2 text-base-content" data-ai-usage-client>
									<option value="all">All clients</option>
									{clientRows.map((client) => <option value={client.key}>{toolMeta[client.key]?.label ?? client.name}</option>)}
								</select>
							</label>
						</div>
					</div>
					<div class="relative h-[340px] w-full"><canvas class="h-full w-full" data-ai-usage-model-chart aria-label="Model usage comparison chart"></canvas></div>
					<div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-xs text-base-content/65" data-ai-usage-model-legend></div>
				</div>

				<div class="border-t border-base-content/10 overflow-x-auto">
					<div class="p-5 sm:p-7">
						<div class="flex items-center justify-between mb-6">
							<h3 class="flex items-center gap-2 text-lg font-extrabold uppercase tracking-wider">
								<span class="inline-block h-5 w-1.5 rounded-sm bg-primary"></span>
								<T tr={UI.section.aiUsage.modelsUsed} />
							</h3>
							<p class="font-mono text-xs text-base-content/50 hidden sm:block">
								{modelRows.length} models
							</p>
						</div>
						{modelRows.length > 0 ? (
							<div>
							<table class="w-full min-w-[680px] border-collapse text-sm" data-ai-usage-model-table>
								<thead>
									<tr class="border-y border-base-content/10 bg-base-200/70 text-left font-mono text-xs uppercase tracking-widest text-info">
										<th class="px-6 py-4 font-medium"><button type="button" data-ai-usage-sort="name">Model</button></th>
										<th class="px-6 py-4 text-right font-medium"><button type="button" data-ai-usage-sort="tokens">Tokens</button></th>
										<th class="px-6 py-4 text-right font-medium"><button type="button" data-ai-usage-sort="cost">Cost</button></th>
										<th class="px-6 py-4 text-right font-medium"><button type="button" data-ai-usage-sort="percentage">%</button></th>
									</tr>
								</thead>
								<tbody>
									{modelRows.map((model) => (
										<tr class="border-b border-base-content/10 odd:bg-base-100/20 even:bg-base-200/45 transition hover:bg-primary/5" data-model-name={model.name} data-model-tokens={Number(model.tokens)} data-model-cost={Number(model.cost)} data-model-percentage={model.percentage}>
											<td class="px-6 py-4 font-bold">
												<span class="inline-flex items-center gap-2">
													<span class={`h-2 w-2 rounded-full ${modelColor(model.name)}`}></span>
													{model.name}
												</span>
											</td>
											<td class="px-6 py-4 text-right font-bold text-base-content">
												{fmtCompactTokens(Number(model.tokens))}
											</td>
											<td class="px-6 py-4 text-right font-bold text-info">
												{fmtCost(Number(model.cost))}
											</td>
											<td class="px-6 py-4 text-right text-info/80">
												{model.percentage.toFixed(1)}%
											</td>
										</tr>
									))}
								</tbody>
							</table>
								<div class="mt-5 flex flex-wrap items-center justify-between gap-3 font-mono text-xs text-base-content/60" data-ai-usage-pagination>
									<label class="flex items-center gap-2">Rows per page
										<select class="rounded-lg border border-base-content/15 bg-base-200 px-2 py-1.5 text-base-content" data-ai-usage-page-size>
											<option value="10">10</option><option value="20">20</option><option value="50">50</option>
										</select>
									</label>
									<div class="flex items-center gap-3">
										<span data-ai-usage-page-info></span>
										<button type="button" class="rounded-lg border border-base-content/15 px-3 py-1.5 transition hover:border-primary disabled:opacity-30" data-ai-usage-page-prev>Previous</button>
										<button type="button" class="rounded-lg border border-base-content/15 px-3 py-1.5 transition hover:border-primary disabled:opacity-30" data-ai-usage-page-next>Next</button>
									</div>
								</div>
							</div>
						) : (
							<div class="px-6 py-10 text-center font-mono text-sm text-base-content/45">
								No model data available
							</div>
						)}
					</div>
				</div>
			</div>

			<div class="reveal flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
				<p class="font-mono text-xs opacity-40">
					<T tr={UI.section.aiUsage.updatedAt} />:{' '}
					{aiUsage.fetchedAt
						? new Date(aiUsage.fetchedAt).toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})
						: '—'}
				</p>
				<a
					href="https://tokscale.ai/u/cicaco07"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 rounded-xl bg-primary/10 px-5 py-2.5 text-sm font-semibold text-primary transition-all hover:bg-primary/20 hover:scale-105"
				>
					<T tr={UI.section.aiUsage.viewOnTokscale} />
					<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
					</svg>
				</a>
			</div>
		</div>

		<script id="ai-usage-data" type="application/json" set:html={chartData}></script>
	</section>
)}
