---
import { UI } from "../i18n";
import T from "./ui/T.astro";

const stats = [
	{ value: "3+", label: UI.hero.statYears },
	{ value: "8+", label: UI.hero.statProj },
	{ value: "3.83", label: UI.hero.statGpa },
	{ value: "605", label: UI.hero.statToeic },
];

const roles = [
	"Fullstack Web Developer",
	"Laravel Engineer",
	"Vue.js Specialist",
	"Nest.js Developer",
];
---

<section
	id="hero"
	class="relative min-h-screen flex items-center justify-center overflow-hidden px-6"
>
	<div class="relative z-10 flex flex-col items-center text-center max-w-4xl">
		<div class="animate-fade-up mb-8"></div>

		<div class="animate-fade-up delay-100 mb-8">
			<div
				class="h-32 w-32 rounded-full p-[3px] animate-pulse-glow"
				style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary), var(--color-accent));"
			>
				<div
					class="flex h-full w-full items-center justify-center rounded-full bg-base-100 text-4xl font-bold text-gradient"
				>
					AD
				</div>
			</div>
		</div>

		<h1
			class="animate-fade-up delay-200 text-4xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl"
		>
			<T tr={UI.hero.greet} />
			<span class="text-gradient"> Aryo Deva Saputra</span>
		</h1>

		<div
			class="animate-fade-up delay-300 mt-4 h-8 flex items-center justify-center"
		>
			<p
				class="text-lg font-medium opacity-70 sm:text-xl lg:text-2xl font-mono"
			>
				<span id="typewriter-text" data-roles={JSON.stringify(roles)}
				></span><span class="typewriter-cursor">|</span>
			</p>
		</div>

		<p
			class="animate-fade-up delay-400 mt-6 max-w-2xl text-base leading-relaxed opacity-60 sm:text-lg"
		>
			<T tr={UI.hero.intro} />
		</p>

		<div
			class="animate-fade-up delay-500 mt-10 flex flex-wrap items-center justify-center gap-0 divide-x divide-base-content/15"
		>
			{
				stats.map((stat) => (
					<div class="flex flex-col items-center px-6 py-2 first:pl-0 last:pr-0">
						<span class="text-2xl font-extrabold text-gradient sm:text-3xl">
							{stat.value}
						</span>
						<span class="mt-0.5 font-mono text-xs opacity-50 uppercase tracking-widest">
							<T tr={stat.label} />
						</span>
					</div>
				))
			}
		</div>

		<div
			class="animate-fade-up delay-600 mt-10 flex flex-wrap items-center justify-center gap-4"
		>
			<a
				href="/projects/"
				class="group relative inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-sm font-semibold text-primary-content shadow-lg transition-all duration-300 hover:scale-105"
				style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); box-shadow: 0 10px 30px color-mix(in oklch, var(--color-primary) 30%, transparent);"
			>
				<T tr={UI.hero.ctaWork} />
				<svg
					class="h-4 w-4 transition-transform group-hover:translate-x-1"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
				</svg>
			</a>
			<a
				href="/contact/"
				class="inline-flex items-center gap-2 rounded-xl border border-base-content/20 px-7 py-3.5 text-sm font-semibold opacity-80 transition-all duration-300 hover:border-primary/40 hover:bg-primary/5 hover:opacity-100 hover:text-primary"
			>
				<T tr={UI.hero.ctaContact} />
			</a>
		</div>

		<div class="animate-fade-in delay-800 mt-20">
			<a
				href="#education"
				class="flex flex-col items-center gap-2 opacity-40 transition-all hover:opacity-100 hover:text-primary"
			>
				<span class="text-xs font-medium uppercase tracking-widest"
					><T tr={UI.hero.scroll} /></span
				>
				<svg
					class="h-5 w-5 animate-bounce"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
				</svg>
			</a>
		</div>
	</div>
</section>

<style>
	.typewriter-cursor {
		display: inline-block;
		animation: blink-cursor 0.8s step-end infinite;
		color: var(--color-primary);
		font-weight: 300;
		margin-left: 1px;
	}
	@keyframes blink-cursor {
		from,
		to {
			opacity: 1;
		}
		50% {
			opacity: 0;
		}
	}
</style>

<script>
	import { initTypewriter } from "../scripts/typewriter";

	const el = document.getElementById("typewriter-text");
	const roles = el ? JSON.parse(el.dataset.roles ?? "[]") : [];
	initTypewriter("typewriter-text", roles);
</script>
