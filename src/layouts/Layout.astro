---
import "../styles/global.css";
import { SITE, NAV_LINKS } from "../config/site";
import { UI } from "../i18n";
import T from "../components/ui/T.astro";
import FloatingLogos from "../components/ui/FloatingLogos.astro";
import aiUsage from "../data/ai-usage.json";

interface Props {
	title?: string;
	description?: string;
}

const { title = SITE.title, description } = Astro.props;
const descId = description ?? SITE.description.id;
const descEn = description ?? SITE.description.en;
const STALE_DAYS = 7;
const isAiUsageAvailable =
	aiUsage.available === true &&
	aiUsage.fetchedAt !== null &&
	Date.now() - new Date(aiUsage.fetchedAt).getTime() <
		STALE_DAYS * 24 * 60 * 60 * 1000;
const navLinks = NAV_LINKS.filter(
	(link) => link.href !== "/ai-usage/" || isAiUsageAvailable,
);
---

<!doctype html>
<html lang="id" data-theme="sunset" data-lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<!-- Preconnect to Google Fonts origins to eliminate DNS+TCP+TLS latency -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://fonts.gstatic.com" />

		<!-- Load Google Fonts asynchronously to prevent render-blocking -->
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			/>
		</noscript>
		<meta
			id="meta-description"
			name="description"
			content={descId}
			data-i18n-id={descId}
			data-i18n-en={descEn}
		/>
		<meta name="theme-color" content="#1a1625" />
		<title>{title}</title>
		<script is:inline>
			(function () {
				try {
					const storedTheme = localStorage.getItem("theme");
					const prefersLight = window.matchMedia(
						"(prefers-color-scheme: light)",
					).matches;
					const theme = storedTheme || (prefersLight ? "acid" : "sunset");
					document.documentElement.setAttribute("data-theme", theme);
				} catch (_) {
					document.documentElement.setAttribute("data-theme", "sunset");
				}
				try {
					var storedLang = localStorage.getItem("lang");
					var lang;
					if (storedLang === "id" || storedLang === "en") {
						lang = storedLang;
					} else {
						var nav =
							(navigator.languages && navigator.languages[0]) ||
							navigator.language ||
							"id";
						lang = String(nav).toLowerCase().indexOf("en") === 0 ? "en" : "id";
					}
					document.documentElement.setAttribute("data-lang", lang);
					document.documentElement.setAttribute("lang", lang);
					var meta = document.getElementById("meta-description");
					if (meta) {
						var c = meta.getAttribute("data-i18n-" + lang);
						if (c) meta.setAttribute("content", c);
					}
				} catch (_) {
					document.documentElement.setAttribute("data-lang", "id");
				}
			})();
		</script>
	</head>
	<body class="min-h-screen antialiased">
		<div class="page-bg" aria-hidden="true">
			<div
				class="page-orb page-orb--primary"
				style="top:-8rem; left:-10rem; height:38rem; width:38rem; opacity:0.22;"
			>
			</div>
			<div
				class="page-orb page-orb--secondary"
				style="top:38%; right:-12rem; height:42rem; width:42rem; opacity:0.18; animation-delay:4s;"
			>
			</div>
			<div
				class="page-orb page-orb--accent"
				style="bottom:-10rem; left:20%; height:34rem; width:34rem; opacity:0.14; animation-delay:2s;"
			>
			</div>
		</div>

		<FloatingLogos />

		<nav
			id="navbar"
			class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
		>
			<div
				class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
			>
				<a href="/" class="text-xl font-bold tracking-tight text-gradient">
					AD<span class="opacity-60">.</span>
				</a>

				<div class="flex items-center gap-2">
					<ul class="hidden items-center gap-1 md:flex">
						{
							navLinks.map((link) => (
								<li>
									<a
										href={link.href}
										class="nav-link relative px-3 py-2 text-sm font-medium opacity-60 transition-opacity hover:opacity-100"
										data-section={
											link.href.startsWith("#") ? link.href.slice(1) : undefined
										}
									>
										<T tr={link.label} />
									</a>
								</li>
							))
						}
					</ul>

					<span
						class="hidden h-5 w-px bg-base-content/15 md:block ml-2 mr-1"
						aria-hidden="true"></span>

					<button
						id="lang-toggle"
						class="lang-toggle relative flex h-10 items-center justify-center rounded-lg px-3 text-xs font-bold tracking-wider transition-colors hover:bg-base-content/5"
						type="button"
						data-i18n-id-aria-label={UI.a11y.toggleLanguage.id}
						data-i18n-en-aria-label={UI.a11y.toggleLanguage.en}
						aria-label={UI.a11y.toggleLanguage.id}
					>
						<span data-lang="id">EN</span><span data-lang="en">ID</span>
					</button>

					<button
						id="theme-toggle"
						class="theme-toggle"
						type="button"
						data-i18n-id-aria-label={UI.a11y.toggleTheme.id}
						data-i18n-en-aria-label={UI.a11y.toggleTheme.en}
						aria-label={UI.a11y.toggleTheme.id}
					>
						<svg
							class="icon-sun h-5 w-5"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							stroke-width="2"
						>
							<circle cx="12" cy="12" r="4" fill="currentColor" stroke="none"
							></circle>
							<path
								stroke-linecap="round"
								d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"
							></path>
						</svg>
						<svg
							class="icon-moon h-5 w-5"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path>
						</svg>
					</button>

					<button
						id="menu-toggle"
						class="relative z-50 flex h-10 w-10 items-center justify-center rounded-lg transition-colors hover:bg-base-content/5 md:hidden"
						type="button"
						data-i18n-id-aria-label={UI.a11y.toggleMenu.id}
						data-i18n-en-aria-label={UI.a11y.toggleMenu.en}
						aria-label={UI.a11y.toggleMenu.id}
					>
						<div class="hamburger-lines flex flex-col gap-1.5">
							<span
								class="block h-0.5 w-6 rounded-full bg-current transition-all duration-300"
							></span>
							<span
								class="block h-0.5 w-4 rounded-full bg-current transition-all duration-300 ml-auto"
							></span>
							<span
								class="block h-0.5 w-6 rounded-full bg-current transition-all duration-300"
							></span>
						</div>
					</button>
				</div>
			</div>
		</nav>

		<div
			id="mobile-menu"
			class="fixed inset-0 z-40 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
			style="background: color-mix(in oklch, var(--color-base-100) 95%, transparent); backdrop-filter: blur(24px);"
		>
			<ul class="flex flex-col items-center gap-6">
				{
					navLinks.map((link, i) => (
						<li>
							<a
								href={link.href}
								class="mobile-nav-link text-2xl font-semibold opacity-80 transition-opacity hover:opacity-100"
								style={`transition-delay: ${i * 60}ms;`}
								data-section={
									link.href.startsWith("#") ? link.href.slice(1) : undefined
								}
							>
								<T tr={link.label} />
							</a>
						</li>
					))
				}
			</ul>
		</div>

		<slot />

		<script>
			import { initThemeToggle } from "../scripts/theme-toggle";
			import { initLangToggle } from "../scripts/lang-toggle";
			import {
				initMobileMenu,
				initNavScroll,
				initNavActiveLink,
			} from "../scripts/navbar";
			import { initReveal } from "../scripts/reveal";
			import { initGsapScroll } from "../scripts/gsap-scroll";

			initGsapScroll();
			initThemeToggle();
			initLangToggle();
			initMobileMenu();
			initNavScroll();
			initNavActiveLink();
			initReveal();
		</script>

		<style is:global>
			#navbar.nav-scrolled {
				background: color-mix(in oklch, var(--color-base-100) 70%, transparent);
				backdrop-filter: blur(16px) saturate(1.5);
				border-bottom: 1px solid
					color-mix(in oklch, var(--color-base-content) 8%, transparent);
			}
			.nav-link.nav-active {
				opacity: 1 !important;
				color: var(--color-primary);
			}
			.lang-toggle {
				color: color-mix(in oklch, var(--color-base-content) 70%, transparent);
				font-family: var(--font-mono, monospace);
			}
			.lang-toggle:hover {
				color: var(--color-primary);
			}
		</style>
	</body>
</html>
