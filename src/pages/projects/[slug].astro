---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { UI } from '../../i18n';
import T from '../../components/ui/T.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.data.slug },
		props: { project },
	}));
}

interface Props {
	project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const { data } = project;
const status = data.status;
const statusLabel =
	status === 'live'           ? UI.projectDetail.statusLive    :
	status === 'in-development' ? UI.projectDetail.statusInDev   :
	status === 'archived'       ? UI.projectDetail.statusArchive : null;
---

<Layout title={`${data.title} — Aryo Deva Saputra`} description={data.description}>
	<main class="relative pt-24 pb-32 px-6">
		<div class="pointer-events-none absolute top-20 left-1/2 -translate-x-1/2 h-[400px] w-[800px] rounded-full opacity-20 blur-3xl" style={`background: radial-gradient(ellipse, var(--color-${data.accent}), transparent 70%);`}></div>

		<div class="relative mx-auto max-w-3xl">
			<a href="/projects/" class="inline-flex items-center gap-2 text-sm opacity-60 hover:opacity-100 hover:text-primary transition-all mb-8">
				<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
				</svg>
				<T tr={UI.projectDetail.back} />
			</a>

			<div class="mb-12">
				<div class="flex flex-wrap items-center gap-3 mb-4">
					<span class={`inline-block rounded-full bg-${data.accent}/10 px-3 py-1 font-mono text-xs font-medium text-${data.accent}`}>
						{data.year}
					</span>
					{statusLabel && (
						<span class={`inline-block rounded-full border border-base-content/20 px-2.5 py-0.5 text-xs font-medium opacity-60`}>
							<T tr={statusLabel} />
						</span>
					)}
				</div>

				<h1 class={`text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl text-${data.accent}`}>
					{data.title}
				</h1>

				<p class="mt-6 text-lg leading-relaxed opacity-80">{data.description}</p>
			</div>

			<div class="glass rounded-2xl p-6 sm:p-8 mb-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
				<div>
					<p class="font-mono text-xs uppercase tracking-widest opacity-50 mb-1.5"><T tr={UI.projectDetail.role} /></p>
					<p class="text-sm font-medium">{data.role}</p>
				</div>
				{data.client && (
					<div>
						<p class="font-mono text-xs uppercase tracking-widest opacity-50 mb-1.5"><T tr={UI.projectDetail.client} /></p>
						<p class="text-sm font-medium">{data.client}</p>
					</div>
				)}
				{data.duration && (
					<div>
						<p class="font-mono text-xs uppercase tracking-widest opacity-50 mb-1.5"><T tr={UI.projectDetail.duration} /></p>
						<p class="text-sm font-medium">{data.duration}</p>
					</div>
				)}
				{data.teamSize && (
					<div>
						<p class="font-mono text-xs uppercase tracking-widest opacity-50 mb-1.5"><T tr={UI.projectDetail.team} /></p>
						<p class="text-sm font-medium">{data.teamSize}</p>
					</div>
				)}
			</div>

			<div class="browser-mockup mb-12">
				<div class="browser-mockup__bar">
					<div class="browser-mockup__dots">
						<span class="browser-mockup__dot browser-mockup__dot--red"></span>
						<span class="browser-mockup__dot browser-mockup__dot--yellow"></span>
						<span class="browser-mockup__dot browser-mockup__dot--green"></span>
					</div>
					<div class="browser-mockup__url">
						<span class="browser-mockup__url-text">{data.slug}.app</span>
					</div>
				</div>
				<div class="browser-mockup__content relative overflow-hidden" style={`background: color-mix(in oklch, var(--color-${data.accent}) 5%, var(--color-base-200)); min-height: 320px;`}>
					{data.coverImage ? (
						<img
							src={data.coverImage}
							alt={`${data.title} preview`}
							class="w-full h-auto object-cover"
							loading="eager"
						/>
					) : (
						<>
							<div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, var(--color-base-content) 1px, transparent 1px); background-size: 20px 20px;"></div>
							<div class="relative h-full min-h-[320px] flex flex-col items-center justify-center p-12 gap-4">
								<div class={`h-20 w-20 rounded-2xl flex items-center justify-center text-2xl font-bold`} style={`background: linear-gradient(135deg, var(--color-${data.accent}), color-mix(in oklch, var(--color-${data.accent}) 60%, var(--color-secondary))); color: white;`}>
									{data.title.split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase()}
								</div>
								<div class="text-center">
									<p class={`text-sm font-mono opacity-60`}><T tr={UI.projectDetail.preview} /></p>
									<p class="text-xs opacity-40 mt-1"><T tr={UI.projectDetail.previewHint} /></p>
								</div>
							</div>
						</>
					)}
				</div>
			</div>

			{data.screenshots && data.screenshots.length > 0 && (
				<div class="mb-12">
					<p class="font-mono text-xs uppercase tracking-widest opacity-50 mb-4">Screenshots</p>
					<div class="grid gap-4 sm:grid-cols-2">
						{data.screenshots.map((shot) => (
							<div class="group relative overflow-hidden rounded-xl border border-base-content/10 bg-base-200/50 transition hover:border-primary/30">
								<img
									src={shot.src}
									alt={shot.alt}
									class="w-full h-auto object-cover transition group-hover:scale-[1.02]"
									loading="lazy"
									decoding="async"
								/>
								<div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-base-300/90 to-transparent p-3 pt-8">
									<p class="text-xs font-medium text-base-content/80">{shot.alt}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			)}

			<div class="mb-12">
				<p class="font-mono text-xs uppercase tracking-widest opacity-50 mb-3"><T tr={UI.projectDetail.techStack} /></p>
				<div class="flex flex-wrap gap-2">
					{data.techStack.map((tech) => (
						<span class="tech-badge">{tech}</span>
					))}
				</div>
			</div>

			{(data.liveUrl || data.githubUrl || data.repoVisibility === 'private') && (
				<div class="flex flex-wrap items-center gap-3 mb-12">
					{data.liveUrl && (
						<a href={data.liveUrl} target="_blank" rel="noopener noreferrer" class={`inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold text-primary-content transition-all hover:scale-105`} style={`background: linear-gradient(135deg, var(--color-${data.accent}), var(--color-secondary));`}>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
							</svg>
							<T tr={UI.projectDetail.visitSite} />
						</a>
					)}
					{data.repoVisibility === 'private' ? (
						<span class="inline-flex items-center gap-2 rounded-xl border border-base-content/20 px-5 py-2.5 text-sm font-semibold opacity-70" title={UI.projects.privateHint.id}>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 11c0-1.657 1.343-3 3-3s3 1.343 3 3v3M5 11h14a2 2 0 012 2v7a2 2 0 01-2 2H5a2 2 0 01-2-2v-7a2 2 0 012-2z" />
							</svg>
							<T tr={UI.projects.privateRepo} />
						</span>
					) : data.githubUrl && (
						<a href={data.githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl border border-base-content/20 px-5 py-2.5 text-sm font-semibold opacity-80 transition-all hover:border-primary/40 hover:bg-primary/5 hover:opacity-100">
							<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
							<T tr={UI.projectDetail.viewSource} />
						</a>
					)}
					{data.repoVisibility === 'private' && (
						<span class="text-xs opacity-50 max-w-md">
							<T tr={UI.projects.privateHint} />
						</span>
					)}
				</div>
			)}

			<article class="project-content prose-custom">
				<Content />
			</article>

			<div class="mt-16 pt-12 border-t border-base-content/10">
				<a href="/#projects" class="inline-flex items-center gap-2 text-sm opacity-60 hover:opacity-100 hover:text-primary transition-all">
					<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
					</svg>
					<T tr={UI.projectDetail.back} />
				</a>
			</div>
		</div>
	</main>
</Layout>
